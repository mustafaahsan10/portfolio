---
import { site } from "../config";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-6 px-6 py-10 sm:flex-row sm:items-center"
  >
    <p class="font-mono text-xs text-muted">
      <span class="text-accent">$</span> © {year} {site.name}
    </p>
    <SocialLinks />
    <p class="font-mono text-xs text-muted">Built with Astro + Tailwind</p>
  </div>
</footer>
