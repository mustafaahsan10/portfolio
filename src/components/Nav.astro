---
import { nav, site } from "../config";

const handle = site.name.split(" ")[0].toLowerCase();
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-bg/70 backdrop-blur">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="font-mono text-sm font-semibold tracking-tight transition-colors hover:text-accent"
    >
      <span class="text-accent">~/</span>{handle}
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-mono text-sm text-muted transition-colors hover:text-accent"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <button
        type="button"
        data-cmdk
        aria-label="Open command menu"
        class="hidden items-center gap-1 rounded border border-border px-2.5 py-1.5 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-accent sm:flex"
      >
        <span aria-hidden="true">⌘</span>K
      </button>

      <a
        href="#contact"
        class="rounded border border-accent/40 bg-accent/10 px-3 py-1.5 font-mono text-sm text-accent transition-colors hover:bg-accent/20"
      >
        Get in touch
      </a>
    </div>
  </nav>
</header>

<script>
  document.querySelectorAll("[data-cmdk]").forEach((btn) =>
    btn.addEventListener("click", () =>
      window.dispatchEvent(new Event("cmdk:open")),
    ),
  );
</script>
