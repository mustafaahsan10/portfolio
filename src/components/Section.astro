---
interface Props {
  id: string;
  index: string; // e.g. "01"
  label: string; // mono slug, e.g. "projects"
  title: string; // display heading
}

const { id, index, label, title } = Astro.props;
---

<section id={id} class="scroll-mt-20 border-t border-border/60 py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <p class="mb-3 font-mono text-sm">
      <span class="text-accent">{index}</span>
      <span class="text-muted">// {label}</span>
    </p>
    <h2 class="mb-10 text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
    <slot />
  </div>
</section>
