---
interface Props {
  group: string;
  items: string[];
}

const { group, items } = Astro.props;
---

<div class="rounded-lg border border-border bg-surface p-5">
  <h3 class="font-mono text-sm text-accent">{group}</h3>
  <ul class="mt-3 flex flex-wrap gap-2 font-mono text-xs">
    {
      items.map((i) => (
        <li class="rounded border border-border px-2 py-1 text-muted">{i}</li>
      ))
    }
  </ul>
</div>
