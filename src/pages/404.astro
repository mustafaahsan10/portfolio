---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page not found">
  <main class="mx-auto flex min-h-dvh max-w-3xl flex-col justify-center px-6">
    <p class="font-mono text-sm text-accent">$ 404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-5xl">
      This page took a wrong turn.
    </h1>
    <p class="mt-4 text-muted">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-block w-fit rounded border border-border px-4 py-2 font-mono text-sm transition-colors hover:border-accent hover:text-accent"
    >
      ← back home
    </a>
  </main>
</BaseLayout>
