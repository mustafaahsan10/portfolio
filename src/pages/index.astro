---
import BaseLayout from "../layouts/BaseLayout.astro";

// Phase 0 placeholder. Phase 1 replaces this with the real hero + sections.
const stack = ["Python", "TypeScript", "React", "LLMs", "RAG", "Next.js"];
---

<BaseLayout>
  <main class="mx-auto flex min-h-dvh max-w-3xl flex-col justify-center px-6 py-24">
    <p class="font-mono text-sm text-accent">~/whoami</p>

    <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-6xl">
      Mustafa Ahsan
    </h1>

    <p class="mt-4 font-mono text-lg text-muted">
      <span class="text-accent">Software Engineer</span> · Generative AI
    </p>

    <p class="mt-6 max-w-xl text-base leading-relaxed text-muted">
      I build LLM-powered products — from prototype to production. Full portfolio
      launching soon.
    </p>

    <ul class="mt-10 flex flex-wrap gap-2.5 font-mono text-sm">
      {
        stack.map((item) => (
          <li class="rounded border border-border bg-surface px-3 py-1 text-muted">
            {item}
          </li>
        ))
      }
    </ul>

    <footer class="mt-16 border-t border-border pt-6 font-mono text-xs text-muted">
      <span class="text-accent">$</span> status: under construction — v0
    </footer>
  </main>
</BaseLayout>
