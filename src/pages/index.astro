---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillGroup from "../components/SkillGroup.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ContactForm from "../components/ContactForm.tsx";
import AskAI from "../components/AskAI.tsx";
import CommandPalette from "../components/CommandPalette.tsx";
import { SUGGESTED_QUESTIONS } from "../data/assistant";
import { site, skills } from "../config";

const all = (await getCollection("projects")).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
const featured = all.filter((p) => p.data.featured);
const projects = featured.length ? featured : all;
const projectRefs = all.map((p) => ({ title: p.data.title, slug: p.id }));
---

<BaseLayout>
  <Nav />

  <main>
    <Hero />

    <Section id="ask" index="00" label="ask-my-portfolio" title="Ask my portfolio">
      <p class="mb-6 max-w-2xl leading-relaxed text-muted">
        This site has an AI assistant trained on my background. Ask it anything
        about my experience, projects, or fit for a role — it answers in real
        time, grounded in my real work.
      </p>
      <div class="max-w-2xl">
        <AskAI client:visible suggestions={SUGGESTED_QUESTIONS} />
      </div>
    </Section>

    <Section id="projects" index="01" label="projects" title="Selected Projects">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Section>

    <Section id="about" index="02" label="about" title="About">
      <div class="max-w-2xl space-y-4 text-base leading-relaxed text-muted">
        {/* EDIT ME — make this yours. */}
        <p>
          I'm a software engineer specializing in <span class="text-fg"
            >generative AI</span
          >. I design and build LLM-powered products end to end — retrieval
          systems, agents, and evaluation pipelines on the backend, and the
          React interfaces that make them feel effortless on the front.
        </p>
        <p>
          I care about shipping things that are reliable, measurable, and
          genuinely useful — not just demos. <span class="text-fg"
            >[Add a personal line here — what you're focused on now, or what you
            do outside of code.]</span
          >
        </p>
      </div>
    </Section>

    <Section id="skills" index="03" label="skills" title="Skills">
      <div class="grid gap-4 sm:grid-cols-2">
        {skills.map((g) => <SkillGroup group={g.group} items={g.items} />)}
      </div>
    </Section>

    <Section id="contact" index="04" label="contact" title="Get in touch">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr]">
        <div class="space-y-5 text-muted">
          <p class="max-w-md leading-relaxed">
            Looking for a software engineer who ships generative-AI products end
            to end? I'd love to hear about the role.
          </p>
          <p class="font-mono text-sm">
            <span class="text-accent">email:</span>
            <a
              href={`mailto:${site.email}`}
              class="underline decoration-border underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
              >{site.email}</a
            >
          </p>
          <SocialLinks />
        </div>

        <ContactForm client:visible accessKey={site.web3formsKey} />
      </div>
    </Section>
  </main>

  <Footer />

  <CommandPalette
    client:idle
    email={site.email}
    github={site.socials.github}
    linkedin={site.socials.linkedin}
    resumeUrl={site.resumeUrl}
    projects={projectRefs}
  />
</BaseLayout>
