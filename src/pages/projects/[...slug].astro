---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import LiteYouTube from "../../components/LiteYouTube.astro";
import { site } from "../../config";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
---

<BaseLayout title={`${d.title} — ${site.name}`} description={d.summary}>
  <main class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <a
      href="/#projects"
      class="font-mono text-sm text-muted transition-colors hover:text-accent"
    >
      ← back to projects
    </a>

    {d.label && <p class="mt-6 font-mono text-xs text-accent">{d.label}</p>}
    <h1
      class:list={[
        "text-3xl font-bold tracking-tight sm:text-4xl",
        d.label ? "mt-2" : "mt-6",
      ]}
    >
      {d.title}
    </h1>
    <p class="mt-3 text-lg text-muted">{d.summary}</p>

    <ul class="mt-5 flex flex-wrap gap-2 font-mono text-xs">
      {
        d.tech.map((t) => (
          <li class="rounded border border-border px-2 py-0.5 text-muted">{t}</li>
        ))
      }
    </ul>

    {
      (d.demoUrl || d.githubUrl) && (
        <div class="mt-6 flex flex-wrap gap-3 font-mono text-sm">
          {d.demoUrl && (
            <a
              href={d.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded bg-accent px-3 py-1.5 text-[#04141a] transition-opacity hover:opacity-90"
            >
              Live demo ↗
            </a>
          )}
          {d.githubUrl && (
            <a
              href={d.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded border border-border px-3 py-1.5 transition-colors hover:border-accent hover:text-accent"
            >
              Code ↗
            </a>
          )}
        </div>
      )
    }

    {
      d.role && (
        <p class="mt-6 font-mono text-sm text-muted">
          <span class="text-accent">role:</span> {d.role}
        </p>
      )
    }

    {
      d.youtubeId && (
        <div class="mt-10">
          <LiteYouTube id={d.youtubeId} title={`${d.title} — walkthrough`} />
        </div>
      )
    }

    <div class="prose mt-10">
      <Content />
    </div>

    {
      d.screenshots && d.screenshots.length > 0 && (
        <div class="mt-12">
          <p class="mb-4 font-mono text-xs text-accent">// screenshots</p>
          <div class="space-y-4">
            {d.screenshots.map((s) => (
              <figure class="overflow-hidden rounded-lg border border-border bg-surface p-2">
                <img
                  src={s.src}
                  alt={s.alt}
                  loading="lazy"
                  class="mx-auto max-h-[620px] w-auto rounded"
                />
                <figcaption class="mt-2 text-center font-mono text-xs text-muted">
                  {s.alt}
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      )
    }

    {
      d.outcome && (
        <div class="mt-10 rounded-lg border border-accent/30 bg-accent/5 p-5">
          <p class="font-mono text-xs text-accent">// outcome</p>
          <p class="mt-2">{d.outcome}</p>
        </div>
      )
    }
  </main>
  <Footer />
</BaseLayout>
